ANTHROPIC_API_KEY=sk-ant-...

# Invoices → Banana (AP) mode reads the LIVE chart of accounts from the client's
# open Banana file via Banana's local webserver. From inside Docker the host is
# reached at host.docker.internal. Enable the webserver in Banana and copy its
# access token here.
BANANA_BASE_URL=https://host.docker.internal:8089
BANANA_TOKEN=
